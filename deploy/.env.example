# Secrets de PRODUCTION consommes par deploy/docker-compose.yaml.
#
# NE PAS committer le vrai .env. En CI il est fourni par la variable protegee
# `DEPLOY_ENV_FILE` (type File) et copie en `.env` a cote du compose sur la VM.
# Valeurs STABLES : ne pas regenerer (volumes SQL/Keycloak persistants existants).
#
# Copier ce fichier en `.env` pour un deploiement manuel local et renseigner les valeurs.

# Mot de passe SA du serveur SQL (complexite MSSQL requise : maj/min/chiffre/symbole).
FAMILYTOOLS_PASSWORD=

# Mot de passe Redis (requirepass).
CACHE_PASSWORD=

# Mot de passe RabbitMQ (utilisateur "guest").
MESSAGING_PASSWORD=

# Mot de passe admin de bootstrap Keycloak.
KEYCLOAK_PASSWORD=

# Secret du client service-account Keycloak (API Accounts <-> Admin Keycloak + realm importe).
ACCOUNT_SVC_SECRET=
